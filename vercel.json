{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "level/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/perfil",
      "dest": "index.js"
    },
    {
      "src": "/level",
      "dest": "level/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
